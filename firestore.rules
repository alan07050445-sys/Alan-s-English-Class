rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper ──────────────────────────────────────────────
    function isTeacher() {
      return request.auth != null
             && request.auth.token.email == 'alan07050445@gmail.com';
    }

    // ── 課程內容（G3/G4/G5/G6 都在 class 集合，G2 在 class-g2）──
    // 公開可讀（維持現狀，避免鎖住學生）；只有老師可寫。
    match /class/{docId} {
      allow read: if true;
      allow write: if isTeacher();
    }
    match /class-g2/{docId} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // ── 學生個人進度（成績 / 完成度 / 錯題）─────────────────
    // 只有「本人」或「老師」可讀；只有本人可寫。
    match /progress/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId || isTeacher());
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ── 學生 XP / Streak / Badges（users 集合）──────────────
    // 本人可讀寫；老師可讀。
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
      allow read: if isTeacher();
    }

    // ── 班級名單（roster）──────────────────────────────────
    // 登入者可讀（顯示同學名字等）；只有老師可寫。
    match /roster/{docId} {
      allow read: if request.auth != null;
      allow write: if isTeacher();
    }

    // ── 全班合作目標（coop）────────────────────────────────
    // 登入者可讀；只有老師可寫（維持現狀）。
    match /coop/{docId} {
      allow read: if request.auth != null;
      allow write: if isTeacher();
    }

    // ── 2026 暑假選課 ───────────────────────────────────────
    // 時段本身沒有個資，公開讀取讓家長只看到「可選 / 已額滿」。
    // 家長留下的姓名與聯絡方式則只允許 Alan 老師查看。
    match /summerSlots2026/{slotId} {
      allow read: if true;
      allow create, delete: if isTeacher();
      allow update: if isTeacher() || (
        resource.data.status == 'open'
        && request.resource.data.status == 'booked'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'bookedAt'])
        && existsAfter(/databases/$(database)/documents/summerBookings2026/$(slotId))
      ) || (
        resource.data.status == 'booked'
        && request.resource.data.status == 'open'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'bookedAt'])
        && getAfter(/databases/$(database)/documents/summerBookings2026/$(slotId)).data.status == 'cancel_requested'
      );
    }

    match /summerBookings2026/{slotId} {
      allow create: if request.resource.data.keys().hasAll([
          'slotId', 'date', 'start', 'end', 'studentName', 'bookingGroup', 'changeToken', 'status', 'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'slotId', 'date', 'start', 'end', 'studentName', 'bookingGroup', 'changeToken', 'status', 'createdAt'
        ])
        && request.resource.data.slotId == slotId
        && request.resource.data.studentName is string
        && request.resource.data.studentName.size() > 0
        && request.resource.data.studentName.size() <= 50
        && request.resource.data.bookingGroup is string
        && request.resource.data.bookingGroup.size() > 0
        && request.resource.data.bookingGroup.size() <= 80
        && request.resource.data.changeToken is string
        && request.resource.data.changeToken.size() > 10
        && getAfter(/databases/$(database)/documents/summerSlots2026/$(slotId)).data.status == 'booked';
      allow update: if isTeacher() || (
        resource.data.status == 'confirmed'
        && request.resource.data.status == 'cancel_requested'
        && request.resource.data.changeToken == resource.data.changeToken
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
      );
      allow read, delete: if isTeacher();
    }

    // ── 其他未列出的文件 ───────────────────────────────────
    // 關鍵修正：舊版這裡是 "allow read: if request.auth != null"，
    // 由於 Firestore 規則是 OR 邏輯，那條會「架空」上面 progress 的限制，
    // 讓任何登入的人都能讀到別人的成績與錯題。
    // 改成「預設拒絕讀取、只有老師可寫」，洩漏即關閉。
    match /{document=**} {
      allow write: if isTeacher();
    }
  }
}
