rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── PDF 檔案 ────────────────────────────────────────────
    // 所有人可讀（學生下載練習卷）
    // 只有老師可以上傳 / 刪除
    match /pdfs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'alan07050445@gmail.com';
    }

    // ── 學生作業照片（v263「上傳作業」題型）─────────────────
    // 學生只能傳到自己的資料夾；只有本人和老師看得到
    match /submissions/{uid}/{allPaths=**} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || request.auth.token.email == 'alan07050445@gmail.com');
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
